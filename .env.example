# ──────────────────────────────────────────────
#  FrameSense Backend – Environment Variables
# ──────────────────────────────────────────────

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=true          # set to false in production

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Model options
YOLO_MODEL=yolov8n.pt     # yolov8n | yolov8s | yolov8m (larger = slower)
MIDAS_MODEL=MiDaS_small   # MiDaS_small | DPT_Hybrid | DPT_Large

# Target inference device: cpu | cuda | mps
DEVICE=cpu
